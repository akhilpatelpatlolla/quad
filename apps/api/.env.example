# Copy to `.env` in this folder (never commit `.env`).

# --- Neon PostgreSQL ---
# Replace YOUR_NEON_PASSWORD with the password from the Neon dashboard.
# Prefer the **pooler** host for apps (more connections, Prisma-friendly):
DATABASE_URL="postgresql://neondb_owner:YOUR_NEON_PASSWORD@ep-long-sound-aolj8a2q-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"
#
# Or **direct** (no pooler) — e.g. for `prisma migrate` from your laptop if pooler is restricted:
# DATABASE_URL="postgresql://neondb_owner:YOUR_NEON_PASSWORD@ep-long-sound-aolj8a2q.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# At least 32 characters (used to sign JWTs)
JWT_SECRET="change-me-to-a-random-string-at-least-32-chars-long"

PORT=4000
CLIENT_URL="http://localhost:5173"
NODE_ENV=development
