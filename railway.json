{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install && npm run build -w apps/api"
  },
  "deploy": {
    "startCommand": "npm run start -w apps/api",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 180
  }
}
